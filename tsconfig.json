{
  "compilerOptions": {
    "lib": [
      "es2022",
      "ESNext.Disposable",
      "dom"
    ],
    "rootDir": "./ts",
    "outDir": "./ext/js",
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "alwaysStrict": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "firefox-webext-browser"
    ],
  },
  "include": [
    "./ts/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "typeAcquisition": {
    "enable": true
  }
}